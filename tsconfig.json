{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "rootDir": "./src",
    "outDir": "./dist",

    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },
    "ignoreDeprecations": "6.0",
    "isolatedModules": true,
    "types": ["node", "jest"],

    "strict": true,

    "esModuleInterop": true,

    "skipLibCheck": true
  },

  "include": ["src", "generated"]
}